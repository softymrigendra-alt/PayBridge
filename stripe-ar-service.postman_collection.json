{
  "info": {
    "name": "Stripe AR Service",
    "description": "API collection for the Stripe Accounts Receivable Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "opportunityId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.success && data.data.token) {",
                  "  pm.collectionVariables.set('token', data.data.token);",
                  "  console.log('Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@arservice.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Sync",
      "item": [
        {
          "name": "Trigger Salesforce Sync",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/api/sync/salesforce", "host": ["{{baseUrl}}"], "path": ["api", "sync", "salesforce"] }
          }
        }
      ]
    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "List Opportunities",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/opportunities?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "opportunities"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Opportunity",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/opportunities/{{opportunityId}}", "host": ["{{baseUrl}}"], "path": ["api", "opportunities", "{{opportunityId}}"] }
          }
        },
        {
          "name": "Fetch Invoice",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/opportunities/{{opportunityId}}/fetch-invoice", "host": ["{{baseUrl}}"], "path": ["api", "opportunities", "{{opportunityId}}", "fetch-invoice"] }
          }
        },
        {
          "name": "Invite Host",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/opportunities/{{opportunityId}}/invite-host", "host": ["{{baseUrl}}"], "path": ["api", "opportunities", "{{opportunityId}}", "invite-host"] }
          }
        },
        {
          "name": "Get Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/opportunities/{{opportunityId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "opportunities", "{{opportunityId}}", "status"] }
          }
        },
        {
          "name": "Create PaymentIntent",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/opportunities/{{opportunityId}}/charge", "host": ["{{baseUrl}}"], "path": ["api", "opportunities", "{{opportunityId}}", "charge"] }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Stripe Webhook (test)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "t=0,v1=test_signature" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": { \"object\": { \"id\": \"pi_test\" } }\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/webhooks/stripe", "host": ["{{baseUrl}}"], "path": ["api", "webhooks", "stripe"] }
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "Get Audit Log",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/audit/{{opportunityId}}", "host": ["{{baseUrl}}"], "path": ["api", "audit", "{{opportunityId}}"] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
