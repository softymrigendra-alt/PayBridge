# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stripe_ar_service

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=replace-this-with-a-long-random-secret-minimum-32-chars
JWT_EXPIRES_IN=24h

# ─── Salesforce ───────────────────────────────────────────────────────────────
# Get from: Setup → App Manager → New Connected App
SALESFORCE_CLIENT_ID=your_salesforce_consumer_key
SALESFORCE_CLIENT_SECRET=your_salesforce_consumer_secret
SALESFORCE_REDIRECT_URI=http://localhost:3001/api/auth/salesforce/callback
SALESFORCE_INSTANCE_URL=https://your-instance.develop.my.salesforce.com
SALESFORCE_USERNAME=your-salesforce-login@example.com
SALESFORCE_PASSWORD=your-salesforce-password
# Get from: Setup → My Personal Information → Reset My Security Token
SALESFORCE_SECURITY_TOKEN=your-security-token

# ─── NetSuite ─────────────────────────────────────────────────────────────────
NETSUITE_ACCOUNT_ID=1234567
NETSUITE_CONSUMER_KEY=your_netsuite_consumer_key
NETSUITE_CONSUMER_SECRET=your_netsuite_consumer_secret
NETSUITE_TOKEN_KEY=your_netsuite_token_key
NETSUITE_TOKEN_SECRET=your_netsuite_token_secret
NETSUITE_BASE_URL=https://1234567.suitetalk.api.netsuite.com

# Set to true to use mock NetSuite data while awaiting real credentials
NETSUITE_MOCK=false

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Get from: stripe listen --forward-to localhost:3001/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Email ────────────────────────────────────────────────────────────────────
# Optional — leave blank to use Ethereal fake SMTP in development
SENDGRID_API_KEY=
EMAIL_FROM=noreply@arservice.com
EMAIL_FROM_NAME=AR Service

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
